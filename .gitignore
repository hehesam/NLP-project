# =============================================================================
# Datasets & confidential data  (NEVER commit — contains real university emails)
# =============================================================================
# Ignore everything under data/, but keep the empty folder skeleton (.gitkeep)
data/**
!data/**/
!data/**/.gitkeep

# Defense-in-depth: never commit raw corpora anywhere in the tree
*.csv
*.jsonl
*.pkl
*.xlsx
*.mbox
*.eml

# Email attachments (may contain personal files)
**/attachments/

# =============================================================================
# Secrets & credentials
# =============================================================================
.env
**/.env
*.key
*.key.pub
*.pem
credentials.json
token.json

