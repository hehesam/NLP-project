# =============================================================================
5_mvp_bot/models/
*.joblib
*.pt
*.bin
*.safetensors

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/

